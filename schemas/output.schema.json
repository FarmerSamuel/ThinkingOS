{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thinkingos.dev/schemas/output.schema.json",
  "title": "ThinkingOS Universal Output",
  "description": "The universal structured output shared by ThinkingOS Skills.",
  "type": "object",
  "required": [
    "summary",
    "evaluation",
    "reasoning",
    "assumptions",
    "missingInformation",
    "questions",
    "nextStep",
    "confidence"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evaluation": {
      "$ref": "evaluation.schema.json"
    },
    "reasoning": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "missingInformation": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "nextStep": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "oneOf": [
        { "type": "string", "enum": ["low", "medium", "high"] },
        { "type": "number", "minimum": 0, "maximum": 1 }
      ]
    }
  },
  "additionalProperties": false
}
