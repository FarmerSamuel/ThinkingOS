{
  "name": "constraints",
  "version": "0.1.0",
  "description": "Identify, classify, and test the boundaries that define the feasible problem space.",
  "purpose": {
    "problem": "Identify, classify, and test the boundaries that define the feasible problem space.",
    "outcome": "Produce validated ConstraintSet, ConstraintClassification, FeasibleSpace.",
    "inScope": [
      "ValidatedProblem",
      "Constraint",
      "Assumption",
      "FeasibleSpace",
      "TradeOff"
    ],
    "outOfScope": [
      "Provider-specific execution",
      "Unvalidated solution generation"
    ]
  },
  "thinkingHabit": "Make governing boundaries explicit before evaluating options.",
  "thinkingElements": [
    "ValidatedProblem",
    "Constraint",
    "Assumption",
    "FeasibleSpace",
    "TradeOff"
  ],
  "requiredInputs": [
    {
      "name": "validatedProblem",
      "description": "The validatedproblem required by Constraints.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "context",
      "description": "The context required by Constraints.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "candidateConstraints",
      "description": "The candidateconstraints required by Constraints.",
      "required": false,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    }
  ],
  "validation": [
    {
      "id": "CONSTRAINTS-V01",
      "description": "Required inputs must be present, relevant, and mutually consistent.",
      "condition": "required inputs pass the shared validation framework",
      "onFailure": "Return needs clarification with one prioritized question."
    },
    {
      "id": "CONSTRAINTS-V02",
      "description": "Material ambiguity and missing information must be surfaced.",
      "condition": "no blocking unknown is hidden",
      "onFailure": "Record the gap and stop dependent logic."
    },
    {
      "id": "CONSTRAINTS-V03",
      "description": "Inputs must satisfy registered dependency semantics.",
      "condition": "dependency outputs or validated equivalents are available",
      "onFailure": "Recommend the missing prerequisite."
    }
  ],
  "logic": [
    {
      "id": "CONSTRAINTS-L01",
      "description": "Identify and normalize the skill's thinking elements: ValidatedProblem, Constraint, Assumption, FeasibleSpace, TradeOff.",
      "condition": "each required element has evidence or explicit unknown status",
      "onFailure": "Request or record the missing element."
    },
    {
      "id": "CONSTRAINTS-L02",
      "description": "Apply the Constraints relationship rules without introducing platform assumptions.",
      "condition": "relationships are explicit and testable",
      "onFailure": "Record the unsupported relationship."
    },
    {
      "id": "CONSTRAINTS-L03",
      "description": "Test contradictions, alternatives, and failure conditions.",
      "condition": "material alternatives are considered",
      "onFailure": "Reduce confidence and disclose the limitation."
    },
    {
      "id": "CONSTRAINTS-L04",
      "description": "Generate a schema-compatible evaluation and next-step recommendation.",
      "condition": "scores, reasoning, and transition are consistent",
      "onFailure": "Return incomplete rather than guessing."
    }
  ],
  "evaluation": {
    "criteria": [
      {
        "name": "Completeness Score",
        "description": "Quality of completeness in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Classification Score",
        "description": "Quality of classification in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Evidence Score",
        "description": "Quality of evidence in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Feasibility Score",
        "description": "Quality of feasibility in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Consistency Score",
        "description": "Quality of consistency in the current reasoning.",
        "weight": 0.2
      }
    ],
    "scoringScale": {
      "minimum": 0,
      "maximum": 4,
      "labels": {
        "0": "unusable",
        "1": "weak",
        "2": "partial",
        "3": "sufficient",
        "4": "robust"
      }
    }
  },
  "conversationRules": [
    "Ask one material question at a time.",
    "Separate facts, assumptions, and interpretations.",
    "Explain why a clarification affects the evaluation.",
    "Stop when inputs are sufficient."
  ],
  "output": {
    "schema": "../../schemas/output.schema.json",
    "extensions": {
      "scoreReporting": {
        "overall": "evaluation.score",
        "dimensions": "reasoning"
      }
    }
  },
  "neverRules": [
    "Never fabricate missing information.",
    "Never bypass a blocking validation failure.",
    "Never hide uncertainty behind a score.",
    "Never invoke an unsatisfied downstream skill."
  ],
  "nextSkill": [
    {
      "skill": "gap-analysis",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with GapAnalysis."
    },
    {
      "skill": "heuristic",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Heuristic."
    },
    {
      "skill": "boundary",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Boundary."
    }
  ],
  "examples": [
    {
      "name": "Valid case",
      "input": {
        "validatedProblem": "Validated input",
        "context": "Relevant context"
      },
      "expectedOutput": {
        "status": "sufficient"
      }
    },
    {
      "name": "Incomplete case",
      "input": {
        "validatedProblem": "Ambiguous input"
      },
      "expectedOutput": {
        "status": "incomplete",
        "questionRequired": true
      }
    }
  ],
  "references": [
    {
      "title": "ThinkingOS Skill Specification",
      "citation": "../../docs/skill-specification.md"
    },
    {
      "title": "ThinkingOS Reasoning Engine",
      "citation": "../../core/engine.md"
    }
  ],
  "tests": [
    {
      "name": "constraints-T01",
      "input": {
        "validatedProblem": "valid input"
      },
      "expected": {
        "check": "successful evaluation"
      }
    },
    {
      "name": "constraints-T02",
      "input": {
        "validatedProblem": "missing required input"
      },
      "expected": {
        "check": "clarification"
      }
    },
    {
      "name": "constraints-T03",
      "input": {
        "validatedProblem": "ambiguous input"
      },
      "expected": {
        "check": "ambiguity detected"
      }
    },
    {
      "name": "constraints-T04",
      "input": {
        "validatedProblem": "contradictory input"
      },
      "expected": {
        "check": "contradiction recorded"
      }
    },
    {
      "name": "constraints-T05",
      "input": {
        "validatedProblem": "unsupported assumption"
      },
      "expected": {
        "check": "assumption disclosed"
      }
    },
    {
      "name": "constraints-T06",
      "input": {
        "validatedProblem": "dependency missing"
      },
      "expected": {
        "check": "prerequisite recommended"
      }
    },
    {
      "name": "constraints-T07",
      "input": {
        "validatedProblem": "alternative explanation"
      },
      "expected": {
        "check": "alternative tested"
      }
    },
    {
      "name": "constraints-T08",
      "input": {
        "validatedProblem": "boundary condition"
      },
      "expected": {
        "check": "boundary handled"
      }
    },
    {
      "name": "constraints-T09",
      "input": {
        "validatedProblem": "low evidence"
      },
      "expected": {
        "check": "confidence reduced"
      }
    },
    {
      "name": "constraints-T10",
      "input": {
        "validatedProblem": "complete input"
      },
      "expected": {
        "check": "output schema conformance"
      }
    }
  ],
  "extensions": {
    "goldenSkillCompatible": true,
    "documentation": {
      "workflow": "workflow.md",
      "validation": "validation.md",
      "evaluation": "evaluation.md",
      "rubric": "rubric.md",
      "examples": "examples.md",
      "tests": "tests.md",
      "references": "references.md"
    }
  }
}
