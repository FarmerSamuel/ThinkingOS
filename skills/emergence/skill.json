{
  "name": "emergence",
  "version": "1.0.0",
  "description": "Identify system-level patterns that arise from interactions and cannot be explained by isolated parts alone.",
  "purpose": {
    "problem": "Identify system-level patterns that arise from interactions and cannot be explained by isolated parts alone.",
    "outcome": "Produce validated EmergentPatterns, SystemBehaviors, EmergenceConditions.",
    "inScope": [
      "Interaction",
      "Pattern",
      "SystemBehavior",
      "EmergenceCondition",
      "AlternativeExplanation"
    ],
    "outOfScope": [
      "Provider-specific execution",
      "Unvalidated solution generation"
    ]
  },
  "thinkingHabit": "Test whether observed patterns arise from interactions before labeling them emergent.",
  "thinkingElements": [
    "Interaction",
    "Pattern",
    "SystemBehavior",
    "EmergenceCondition",
    "AlternativeExplanation"
  ],
  "requiredInputs": [
    {
      "name": "complexityProfile",
      "description": "The complexityprofile required by Emergence.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "interactionMap",
      "description": "The interactionmap required by Emergence.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "associations",
      "description": "The associations required by Emergence.",
      "required": false,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    }
  ],
  "validation": [
    {
      "id": "EMERGENCE-V01",
      "description": "Required inputs must be present, relevant, and mutually consistent.",
      "condition": "required inputs pass the shared validation framework",
      "onFailure": "Return needs clarification with one prioritized question."
    },
    {
      "id": "EMERGENCE-V02",
      "description": "Material ambiguity and missing information must be surfaced.",
      "condition": "no blocking unknown is hidden",
      "onFailure": "Record the gap and stop dependent logic."
    },
    {
      "id": "EMERGENCE-V03",
      "description": "Inputs must satisfy registered dependency semantics.",
      "condition": "dependency outputs or validated equivalents are available",
      "onFailure": "Recommend the missing prerequisite."
    }
  ],
  "logic": [
    {
      "id": "EMERGENCE-L01",
      "description": "Identify and normalize the skill's thinking elements: Interaction, Pattern, SystemBehavior, EmergenceCondition, AlternativeExplanation.",
      "condition": "each required element has evidence or explicit unknown status",
      "onFailure": "Request or record the missing element."
    },
    {
      "id": "EMERGENCE-L02",
      "description": "Apply the Emergence relationship rules without introducing platform assumptions.",
      "condition": "relationships are explicit and testable",
      "onFailure": "Record the unsupported relationship."
    },
    {
      "id": "EMERGENCE-L03",
      "description": "Test contradictions, alternatives, and failure conditions.",
      "condition": "material alternatives are considered",
      "onFailure": "Reduce confidence and disclose the limitation."
    },
    {
      "id": "EMERGENCE-L04",
      "description": "Generate a schema-compatible evaluation and next-step recommendation.",
      "condition": "scores, reasoning, and transition are consistent",
      "onFailure": "Return incomplete rather than guessing."
    }
  ],
  "evaluation": {
    "criteria": [
      {
        "name": "PatternEvidence Score",
        "description": "Quality of patternevidence in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "InteractionBasis Score",
        "description": "Quality of interactionbasis in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "LevelDistinction Score",
        "description": "Quality of leveldistinction in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "AlternativeTesting Score",
        "description": "Quality of alternativetesting in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "PredictiveUse Score",
        "description": "Quality of predictiveuse in the current reasoning.",
        "weight": 0.2
      }
    ],
    "scoringScale": {
      "minimum": 0,
      "maximum": 4,
      "labels": {
        "0": "unusable",
        "1": "weak",
        "2": "partial",
        "3": "sufficient",
        "4": "robust"
      }
    }
  },
  "conversationRules": [
    "Ask one material question at a time.",
    "Separate facts, assumptions, and interpretations.",
    "Explain why a clarification affects the evaluation.",
    "Stop when inputs are sufficient."
  ],
  "output": {
    "schema": "../../schemas/output.schema.json",
    "extensions": {
      "scoreReporting": {
        "overall": "evaluation.score",
        "dimensions": "reasoning"
      }
    }
  },
  "neverRules": [
    "Never fabricate missing information.",
    "Never bypass a blocking validation failure.",
    "Never hide uncertainty behind a score.",
    "Never invoke an unsatisfied downstream skill."
  ],
  "nextSkill": [
    {
      "skill": "boundary",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Boundary."
    },
    {
      "skill": "complexity",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Complexity."
    }
  ],
  "examples": [
    {
      "name": "Valid case",
      "input": {
        "complexityProfile": "Validated input",
        "interactionMap": "Relevant context"
      },
      "expectedOutput": {
        "status": "sufficient"
      }
    },
    {
      "name": "Incomplete case",
      "input": {
        "complexityProfile": "Ambiguous input"
      },
      "expectedOutput": {
        "status": "incomplete",
        "questionRequired": true
      }
    }
  ],
  "references": [
    {
      "title": "ThinkingOS Skill Specification",
      "citation": "../../docs/skill-specification.md"
    },
    {
      "title": "ThinkingOS Reasoning Engine",
      "citation": "../../core/engine.md"
    }
  ],
  "tests": [
    {
      "name": "emergence-T01",
      "input": {
        "complexityProfile": "valid input"
      },
      "expected": {
        "check": "successful evaluation"
      }
    },
    {
      "name": "emergence-T02",
      "input": {
        "complexityProfile": "missing required input"
      },
      "expected": {
        "check": "clarification"
      }
    },
    {
      "name": "emergence-T03",
      "input": {
        "complexityProfile": "ambiguous input"
      },
      "expected": {
        "check": "ambiguity detected"
      }
    },
    {
      "name": "emergence-T04",
      "input": {
        "complexityProfile": "contradictory input"
      },
      "expected": {
        "check": "contradiction recorded"
      }
    },
    {
      "name": "emergence-T05",
      "input": {
        "complexityProfile": "unsupported assumption"
      },
      "expected": {
        "check": "assumption disclosed"
      }
    },
    {
      "name": "emergence-T06",
      "input": {
        "complexityProfile": "dependency missing"
      },
      "expected": {
        "check": "prerequisite recommended"
      }
    },
    {
      "name": "emergence-T07",
      "input": {
        "complexityProfile": "alternative explanation"
      },
      "expected": {
        "check": "alternative tested"
      }
    },
    {
      "name": "emergence-T08",
      "input": {
        "complexityProfile": "boundary condition"
      },
      "expected": {
        "check": "boundary handled"
      }
    },
    {
      "name": "emergence-T09",
      "input": {
        "complexityProfile": "low evidence"
      },
      "expected": {
        "check": "confidence reduced"
      }
    },
    {
      "name": "emergence-T10",
      "input": {
        "complexityProfile": "complete input"
      },
      "expected": {
        "check": "output schema conformance"
      }
    }
  ],
  "extensions": {
    "goldenSkillCompatible": true,
    "documentation": {
      "workflow": "workflow.md",
      "validation": "validation.md",
      "evaluation": "evaluation.md",
      "rubric": "rubric.md",
      "examples": "examples.md",
      "tests": "tests.md",
      "references": "references.md"
    }
  }
}
