{
  "name": "complexity",
  "version": "1.0.0",
  "description": "Evaluate interaction, dependency, uncertainty, and adaptation within a bounded system.",
  "purpose": {
    "problem": "Evaluate interaction, dependency, uncertainty, and adaptation within a bounded system.",
    "outcome": "Produce validated ComplexityProfile, InteractionMap, UncertaintyDrivers.",
    "inScope": [
      "Component",
      "Interaction",
      "Dependency",
      "UncertaintyDriver",
      "FeedbackLoop"
    ],
    "outOfScope": [
      "Provider-specific execution",
      "Unvalidated solution generation"
    ]
  },
  "thinkingHabit": "Examine relationships and behavior rather than counting parts alone.",
  "thinkingElements": [
    "Component",
    "Interaction",
    "Dependency",
    "UncertaintyDriver",
    "FeedbackLoop"
  ],
  "requiredInputs": [
    {
      "name": "problemComponents",
      "description": "The problemcomponents required by Complexity.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "systemBoundary",
      "description": "The systemboundary required by Complexity.",
      "required": true,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    },
    {
      "name": "dependencyStructure",
      "description": "The dependencystructure required by Complexity.",
      "required": false,
      "schema": {
        "type": [
          "string",
          "object",
          "array"
        ]
      }
    }
  ],
  "validation": [
    {
      "id": "COMPLEXITY-V01",
      "description": "Required inputs must be present, relevant, and mutually consistent.",
      "condition": "required inputs pass the shared validation framework",
      "onFailure": "Return needs clarification with one prioritized question."
    },
    {
      "id": "COMPLEXITY-V02",
      "description": "Material ambiguity and missing information must be surfaced.",
      "condition": "no blocking unknown is hidden",
      "onFailure": "Record the gap and stop dependent logic."
    },
    {
      "id": "COMPLEXITY-V03",
      "description": "Inputs must satisfy registered dependency semantics.",
      "condition": "dependency outputs or validated equivalents are available",
      "onFailure": "Recommend the missing prerequisite."
    }
  ],
  "logic": [
    {
      "id": "COMPLEXITY-L01",
      "description": "Identify and normalize the skill's thinking elements: Component, Interaction, Dependency, UncertaintyDriver, FeedbackLoop.",
      "condition": "each required element has evidence or explicit unknown status",
      "onFailure": "Request or record the missing element."
    },
    {
      "id": "COMPLEXITY-L02",
      "description": "Apply the Complexity relationship rules without introducing platform assumptions.",
      "condition": "relationships are explicit and testable",
      "onFailure": "Record the unsupported relationship."
    },
    {
      "id": "COMPLEXITY-L03",
      "description": "Test contradictions, alternatives, and failure conditions.",
      "condition": "material alternatives are considered",
      "onFailure": "Reduce confidence and disclose the limitation."
    },
    {
      "id": "COMPLEXITY-L04",
      "description": "Generate a schema-compatible evaluation and next-step recommendation.",
      "condition": "scores, reasoning, and transition are consistent",
      "onFailure": "Return incomplete rather than guessing."
    }
  ],
  "evaluation": {
    "criteria": [
      {
        "name": "InteractionCoverage Score",
        "description": "Quality of interactioncoverage in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "DependencyQuality Score",
        "description": "Quality of dependencyquality in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Uncertainty Score",
        "description": "Quality of uncertainty in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "Adaptation Score",
        "description": "Quality of adaptation in the current reasoning.",
        "weight": 0.2
      },
      {
        "name": "ExplanatoryPower Score",
        "description": "Quality of explanatorypower in the current reasoning.",
        "weight": 0.2
      }
    ],
    "scoringScale": {
      "minimum": 0,
      "maximum": 4,
      "labels": {
        "0": "unusable",
        "1": "weak",
        "2": "partial",
        "3": "sufficient",
        "4": "robust"
      }
    }
  },
  "conversationRules": [
    "Ask one material question at a time.",
    "Separate facts, assumptions, and interpretations.",
    "Explain why a clarification affects the evaluation.",
    "Stop when inputs are sufficient."
  ],
  "output": {
    "schema": "../../schemas/output.schema.json",
    "extensions": {
      "scoreReporting": {
        "overall": "evaluation.score",
        "dimensions": "reasoning"
      }
    }
  },
  "neverRules": [
    "Never fabricate missing information.",
    "Never bypass a blocking validation failure.",
    "Never hide uncertainty behind a score.",
    "Never invoke an unsatisfied downstream skill."
  ],
  "nextSkill": [
    {
      "skill": "emergence",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Emergence."
    },
    {
      "skill": "heuristic",
      "condition": "The current output satisfies the registered transition contract.",
      "reason": "Continue reasoning with Heuristic."
    }
  ],
  "examples": [
    {
      "name": "Valid case",
      "input": {
        "problemComponents": "Validated input",
        "systemBoundary": "Relevant context"
      },
      "expectedOutput": {
        "status": "sufficient"
      }
    },
    {
      "name": "Incomplete case",
      "input": {
        "problemComponents": "Ambiguous input"
      },
      "expectedOutput": {
        "status": "incomplete",
        "questionRequired": true
      }
    }
  ],
  "references": [
    {
      "title": "ThinkingOS Skill Specification",
      "citation": "../../docs/skill-specification.md"
    },
    {
      "title": "ThinkingOS Reasoning Engine",
      "citation": "../../core/engine.md"
    }
  ],
  "tests": [
    {
      "name": "complexity-T01",
      "input": {
        "problemComponents": "valid input"
      },
      "expected": {
        "check": "successful evaluation"
      }
    },
    {
      "name": "complexity-T02",
      "input": {
        "problemComponents": "missing required input"
      },
      "expected": {
        "check": "clarification"
      }
    },
    {
      "name": "complexity-T03",
      "input": {
        "problemComponents": "ambiguous input"
      },
      "expected": {
        "check": "ambiguity detected"
      }
    },
    {
      "name": "complexity-T04",
      "input": {
        "problemComponents": "contradictory input"
      },
      "expected": {
        "check": "contradiction recorded"
      }
    },
    {
      "name": "complexity-T05",
      "input": {
        "problemComponents": "unsupported assumption"
      },
      "expected": {
        "check": "assumption disclosed"
      }
    },
    {
      "name": "complexity-T06",
      "input": {
        "problemComponents": "dependency missing"
      },
      "expected": {
        "check": "prerequisite recommended"
      }
    },
    {
      "name": "complexity-T07",
      "input": {
        "problemComponents": "alternative explanation"
      },
      "expected": {
        "check": "alternative tested"
      }
    },
    {
      "name": "complexity-T08",
      "input": {
        "problemComponents": "boundary condition"
      },
      "expected": {
        "check": "boundary handled"
      }
    },
    {
      "name": "complexity-T09",
      "input": {
        "problemComponents": "low evidence"
      },
      "expected": {
        "check": "confidence reduced"
      }
    },
    {
      "name": "complexity-T10",
      "input": {
        "problemComponents": "complete input"
      },
      "expected": {
        "check": "output schema conformance"
      }
    }
  ],
  "extensions": {
    "goldenSkillCompatible": true,
    "documentation": {
      "workflow": "workflow.md",
      "validation": "validation.md",
      "evaluation": "evaluation.md",
      "rubric": "rubric.md",
      "examples": "examples.md",
      "tests": "tests.md",
      "references": "references.md"
    }
  }
}
